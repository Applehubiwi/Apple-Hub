local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local Kazy = {}

function Kazy:CreateWindow(Config)
    local HubName = Config.Name or "Kazy Hub"
    local ToggleText = Config.ToggleText or "K" -- Người dùng tự chỉnh chữ ở đây

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "Kazy_UI"
    ScreenGui.Parent = game.CoreGui
    ScreenGui.ResetOnSpawn = false

    -- 1. NÚT ĐÓNG/MỞ (FLOATING BUTTON)
    local ToggleBtn = Instance.new("TextButton")
    local ToggleCorner = Instance.new("UICorner")
    ToggleBtn.Name = "KazyToggle"
    ToggleBtn.Parent = ScreenGui
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    ToggleBtn.Position = UDim2.new(0, 15, 0.5, -20)
    ToggleBtn.Size = UDim2.new(0, 45, 0, 45)
    ToggleBtn.Text = ToggleText
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 140, 0)
    ToggleBtn.TextSize = 22
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleCorner.CornerRadius = UDim.new(1, 0)
    ToggleCorner.Parent = ToggleBtn

    -- 2. KHUNG CHÍNH (MAIN FRAME)
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    MainFrame.Position = UDim2.new(0.5, -160, 0.5, -130)
    MainFrame.Size = UDim2.new(0, 320, 0, 260)
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

    local TopBar = Instance.new("Frame")
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    TopBar.Parent = MainFrame
    Instance.new("UICorner", TopBar)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -10, 1, 0)
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.Text = HubName .. " | KAZY"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.Parent = TopBar

    local Content = Instance.new("ScrollingFrame")
    Content.Size = UDim2.new(1, -10, 1, -45)
    Content.Position = UDim2.new(0, 5, 0, 40)
    Content.BackgroundTransparency = 1
    Content.ScrollBarThickness = 2
    Content.Parent = MainFrame
    local Layout = Instance.new("UIListLayout", Content)
    Layout.Padding = UDim.new(0, 8)
    Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    -- [HỆ THỐNG KÉO THẢ]
    local function MakeDraggable(obj, target)
        local dragging, dragInput, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true; dragStart = input.Position; startPos = target.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MousePointer) then
                dragInput = input
            end
        end)
        RunService.Heartbeat:Connect(function()
            if dragging and dragInput then
                local delta = dragInput.Position - dragStart
                target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false; dragInput = nil
            end
        end)
    end
    MakeDraggable(TopBar, MainFrame)
    MakeDraggable(ToggleBtn, ToggleBtn)

    -- [XỬ LÝ ĐÓNG MỞ]
    ToggleBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
    end)

    local Elements = {}
    local function UpdateCanvas()
        Content.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
    end

    -- [ADD BUTTON]
    function Elements:AddButton(info)
        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(0.95, 0, 0, 35)
        Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        Btn.Text = info.Name
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        Btn.Font = Enum.Font.Gotham
        Btn.Parent = Content
        Instance.new("UICorner", Btn)
        Btn.MouseButton1Click:Connect(info.Callback)
        UpdateCanvas()
    end

    -- [ADD TOGGLE]
    function Elements:AddToggle(info)
        local state = false
        local Tgl = Instance.new("TextButton")
        Tgl.Size = UDim2.new(0.95, 0, 0, 38)
        Tgl.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        Tgl.Text = "  " .. info.Name
        Tgl.TextColor3 = Color3.fromRGB(255, 255, 255)
        Tgl.TextXAlignment = Enum.TextXAlignment.Left
        Tgl.Font = Enum.Font.Gotham
        Tgl.Parent = Content
        Instance.new("UICorner", Tgl)

        local Ind = Instance.new("Frame")
        Ind.Size = UDim2.new(0, 20, 0, 20)
        Ind.Position = UDim2.new(0.88, 0, 0.25, 0)
        Ind.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        Ind.Parent = Tgl
        Instance.new("UICorner", Ind).CornerRadius = UDim.new(1, 0)

        Tgl.MouseButton1Click:Connect(function()
            state = not state
            Ind.BackgroundColor3 = state and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
            info.Callback(state)
        end)
        UpdateCanvas()
    end

    -- [ADD SLIDER]
    function Elements:AddSlider(info)
        local SFrame = Instance.new("Frame")
        SFrame.Size = UDim2.new(0.95, 0, 0, 45)
        SFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        SFrame.Parent = Content
        Instance.new("UICorner", SFrame)

        local Lab = Instance.new("TextLabel")
        Lab.Text = "  " .. info.Name .. ": " .. info.Default
        Lab.Size = UDim2.new(1, 0, 0, 20)
        Lab.TextColor3 = Color3.fromRGB(255, 255, 255)
        Lab.BackgroundTransparency = 1
        Lab.TextXAlignment = Enum.TextXAlignment.Left
        Lab.Parent = SFrame

        local Bar = Instance.new("Frame")
        Bar.Size = UDim2.new(0.9, 0, 0, 5)
        Bar.Position = UDim2.new(0.05, 0, 0.7, 0)
        Bar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        Bar.Parent = SFrame
        local Fill = Instance.new("Frame")
        Fill.Size = UDim2.new((info.Default-info.Min)/(info.Max-info.Min), 0, 1, 0)
        Fill.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
        Fill.Parent = Bar
        Instance.new("UICorner", Fill)

        Bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                local con; con = UserInputService.InputChanged:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                        local p = math.clamp((i.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                        Fill.Size = UDim2.new(p, 0, 1, 0)
                        local v = math.floor(info.Min + (info.Max - info.Min) * p)
                        Lab.Text = "  " .. info.Name .. ": " .. v
                        info.Callback(v)
                    end
                end)
                UserInputService.InputEnded:Connect(function() con:Disconnect() end)
            end
        end)
        UpdateCanvas()
    end

    -- [ADD LABEL]
    function Elements:AddLabel(text)
        local L = Instance.new("TextLabel")
        L.Size = UDim2.new(0.95, 0, 0, 25)
        L.BackgroundTransparency = 1
        L.Text = text
        L.TextColor3 = Color3.fromRGB(150, 150, 150)
        L.Font = Enum.Font.GothamItalic
        L.Parent = Content
        UpdateCanvas()
    end

    return Elements
end

return Kazy
